---
import BaseLayout from "../layouts/BaseLayout.astro";
import RateCards from "../components/RateCards.astro";
import GearTable from "../components/GearTable.astro";
import Faq from "../components/Faq.astro";
import { getGear } from "../lib/cms";
import { FAQ, RATES, SITE } from "../lib/site";

const gear = await getGear();

const jsonld = [
  {
    "@context": "https://schema.org",
    "@type": "OfferCatalog",
    name: "Glasswing studio rates",
    url: SITE.url + "/rates",
    itemListElement: RATES.map((r, i) => ({
      "@type": "Offer",
      position: i + 1,
      name: `${r.label} studio rental`,
      price: r.price.replace(/[^0-9]/g, ""),
      priceCurrency: "EUR",
      description: r.note,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: FAQ.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  },
];
---
<BaseLayout title="Rates & Gear" description="Hourly and full-day studio rates in Prague, plus the full grip list included with every booking. The price is on the page." jsonld={jsonld}>
  <!-- Header -->
  <section class="mx-auto max-w-[1440px] px-5 md:px-16 pt-12 md:pt-20 pb-12">
    <div class="flex gap-5">
      <div class="light-line shrink-0"></div>
      <div>
        <span class="kicker text-primary block mb-3">Rates & gear</span>
        <h1 class="font-display font-black uppercase tracking-tight text-4xl md:text-6xl leading-[0.95]">The price is on the page</h1>
        <p class="text-muted text-lg mt-5 max-w-xl">Straightforward pricing based on the sun's path and the room's utility. Both studios, same rate. Grip kit included; VAT not included. A €15 cleaning fee applies to every booking.</p>
      </div>
    </div>
  </section>

  <!-- Rates -->
  <section class="mx-auto max-w-[1440px] px-5 md:px-16 pb-section">
    <RateCards />
  </section>

  <!-- Gear inventory -->
  <section class="bg-surface border-y border-border">
    <div class="mx-auto max-w-[1440px] px-5 md:px-16 py-section">
      <div class="mb-10 reveal">
        <span class="kicker text-primary block mb-4">Gear inventory</span>
        <h2 class="font-display font-bold uppercase text-2xl md:text-4xl tracking-tight">Included with every booking</h2>
        <p class="text-muted text-lg mt-4 max-w-xl">Industrial-grade grip, maintained weekly. The essentials are complimentary — bring your camera and your lights if you want them.</p>
      </div>
      <GearTable gear={gear} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-[1440px] px-5 md:px-16 py-section grid grid-cols-1 md:grid-cols-12 gap-10">
    <div class="md:col-span-4 reveal">
      <span class="kicker text-primary block mb-4">Questions</span>
      <h2 class="font-display font-bold uppercase text-2xl md:text-4xl tracking-tight">Before you book</h2>
      <a href="/book" class="btn-primary mt-8">Check a date</a>
    </div>
    <div class="md:col-span-8 reveal"><Faq /></div>
  </section>
</BaseLayout>
