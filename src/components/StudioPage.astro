---
import BaseLayout from "../layouts/BaseLayout.astro";
import WindowWall from "./WindowWall.astro";
import SunPath from "./SunPath.astro";
import type { GearItem } from "../lib/cms";

interface Spec { k: string; v: string; }
interface Props {
  name: string;
  index: string;
  location: string;
  variant: "north" | "depot";
  lede: string;
  body: string;
  specs: Spec[];
  gear: GearItem[];
  showSunPath?: boolean;
  title: string;
  description: string;
  jsonld?: Record<string, unknown>[];
}
const { name, index, location, variant, lede, body, specs, gear, showSunPath = false, title, description, jsonld = [] } = Astro.props;
---
<BaseLayout title={title} description={description} jsonld={jsonld}>
  <!-- Hero -->
  <header class="relative h-[58vh] min-h-[420px] flex items-end -mt-20 pt-20 border-b border-border">
    <WindowWall variant={variant} cols={8} rows={6} class="absolute inset-0" label={`${name} — north-facing daylight interior`} />
    <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-background to-transparent"></div>
    <div class="relative mx-auto max-w-[1440px] w-full px-5 md:px-16 pb-10">
      <span class="kicker text-primary block mb-3">{location}</span>
      <h1 class="font-display font-black uppercase tracking-tight text-5xl md:text-7xl lg:text-8xl leading-[0.9]">{name}</h1>
    </div>
  </header>

  <!-- Intro + spec grid -->
  <section class="mx-auto max-w-[1440px] px-5 md:px-16 py-section grid grid-cols-1 md:grid-cols-12 gap-10">
    <div class="md:col-span-5 reveal">
      <div class="flex gap-5">
        <div class="light-line shrink-0"></div>
        <div>
          <h2 class="font-display font-bold uppercase text-2xl md:text-3xl tracking-tight leading-tight">{lede}</h2>
          <p class="text-muted text-lg mt-5">{body}</p>
        </div>
      </div>
    </div>
    <dl class="md:col-span-7 grid grid-cols-2 gap-px bg-border border border-border self-start">
      {specs.map((s) => (
        <div class="bg-surface p-6">
          <dt class="kicker text-muted mb-3">{s.k}</dt>
          <dd class="spec-numeral text-2xl md:text-4xl text-primary">{s.v}</dd>
        </div>
      ))}
    </dl>
  </section>

  {showSunPath && (
    <section class="bg-surface border-y border-border">
      <div class="mx-auto max-w-[1440px] px-5 md:px-16 py-section">
        <div class="mb-12 reveal">
          <span class="kicker text-primary block mb-4">North light integrity</span>
          <h2 class="font-display font-bold uppercase text-2xl md:text-4xl tracking-tight">Where the light falls</h2>
        </div>
        <div class="reveal"><SunPath /></div>
      </div>
    </section>
  )}

  <!-- In-house gear -->
  {gear.length > 0 && (
    <section class="mx-auto max-w-[1440px] px-5 md:px-16 py-section">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10 reveal">
        <div>
          <span class="kicker text-primary block mb-4">In-house gear</span>
          <h2 class="font-display font-bold uppercase text-2xl md:text-4xl tracking-tight">Already in the room</h2>
        </div>
        <a href="/rates" class="kicker text-primary underline underline-offset-8 hover:opacity-70 shrink-0">Full kit list →</a>
      </div>
      <div class="border-t border-border">
        {gear.map((g) => (
          <div class="grid grid-cols-1 md:grid-cols-12 gap-2 md:gap-6 items-baseline py-5 border-b border-border reveal">
            <span class="md:col-span-3 kicker text-muted">{g.category}</span>
            <span class="md:col-span-7">{g.name}<span class="block text-sm text-muted mt-1">{g.specNote}</span></span>
            <span class:list={["md:col-span-2 md:text-right kicker", g.included ? "text-primary" : "text-muted"]}>{g.included ? "Included" : g.hourlyAddOn}</span>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- CTA band -->
  <section class="bg-dark text-on-dark">
    <div class="mx-auto max-w-[1440px] px-5 md:px-16 py-20 text-center">
      <div class="light-line h-10 w-px mx-auto mb-7"></div>
      <h2 class="font-display font-bold uppercase text-3xl md:text-4xl tracking-tight">Claim an hour in {name}</h2>
      <p class="text-on-dark/70 text-lg mt-4 max-w-md mx-auto">Tell us the date. We reply the same day and send the door code.</p>
      <a href={`/book?studio=${encodeURIComponent(name)}`} class="btn-primary mt-8">Check a date</a>
    </div>
  </section>
</BaseLayout>
