# Wix Headless credentials.
# Do NOT commit real values — copy this file to `.env.local` and fill it in.
#
# Easiest way to populate `.env.local`: link a Wix Headless project, then run
#   npx @wix/cli@latest env pull --json
# or copy the values from your Wix dashboard:
#   Settings → Headless Settings → OAuth apps

WIX_CLIENT_ID=
WIX_CLIENT_SECRET=
WIX_CLIENT_INSTANCE_ID=
WIX_CLIENT_PUBLIC_KEY=
WIX_CLOUD_PROVIDER=
