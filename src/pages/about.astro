---
import BaseLayout from "../layouts/BaseLayout.astro";
import WindowWall from "../components/WindowWall.astro";
import { getStory } from "../lib/cms";

const story = await getStory();
const heading = story?.heading ?? "From tram depot to daylight studios";
const paragraphs = (story?.body ?? "").split(/\n\n+/).filter(Boolean);
---
<BaseLayout title="The Depot" description="How a 1920s Prague tram depot became two north-facing daylight photo studios.">
  <!-- Hero -->
  <header class="relative h-[46vh] min-h-[360px] flex items-end -mt-20 pt-20 border-b border-border">
    <WindowWall variant="detail" cols={6} rows={5} class="absolute inset-0" label="The depot's original mullioned glass" />
    <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-background to-transparent"></div>
    <div class="relative mx-auto max-w-[1440px] w-full px-5 md:px-16 pb-10">
      <span class="kicker text-primary block mb-3">The Depot · since 2019</span>
      <h1 class="font-display font-black uppercase tracking-tight text-4xl md:text-6xl leading-[0.95]">{heading}</h1>
    </div>
  </header>

  <!-- Story -->
  <article class="mx-auto max-w-[1440px] px-5 md:px-16 py-section grid grid-cols-1 md:grid-cols-12 gap-10">
    <div class="md:col-span-3 reveal">
      <div class="light-line h-16 w-px mb-4"></div>
      <p class="kicker text-muted">Trams until 1978 · studios since 2019</p>
    </div>
    <div class="md:col-span-8 lg:col-span-7 space-y-6 reveal">
      {paragraphs.map((p) => <p class="text-lg md:text-xl leading-relaxed">{p}</p>)}
    </div>
  </article>

  <!-- Two studios callout -->
  <section class="bg-surface border-y border-border">
    <div class="mx-auto max-w-[1440px] px-5 md:px-16 py-section grid grid-cols-1 md:grid-cols-2 gap-10">
      {[
        { href: "/studio-north", variant: "north", name: "Studio North", note: "North for the glass." },
        { href: "/studio-depot", variant: "depot", name: "Studio Depot", note: "Depot for the drive-in." },
      ].map((s) => (
        <a href={s.href} class="group block reveal">
          <div class="relative aspect-[16/9] border border-border overflow-hidden">
            <WindowWall variant={s.variant as "north" | "depot"} class="absolute inset-0 transition-transform duration-700 group-hover:scale-[1.03]" label={s.name} />
          </div>
          <div class="flex items-baseline justify-between border-b border-border pt-5 pb-4">
            <h2 class="font-display font-bold uppercase text-xl md:text-2xl">{s.name}</h2>
            <span class="text-muted">{s.note}</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-[1440px] px-5 md:px-16 py-20 text-center">
    <div class="light-line h-10 w-px mx-auto mb-7 reveal"></div>
    <h2 class="font-display font-bold uppercase text-3xl md:text-4xl tracking-tight reveal">See the studios</h2>
    <p class="text-muted text-lg mt-4 max-w-md mx-auto reveal">Booked the way we'd want to rent it — by the hour, gear in the room, the light included.</p>
    <a href="/book" class="btn-primary mt-8 reveal">Check a date</a>
  </section>
</BaseLayout>
