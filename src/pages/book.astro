---
import BaseLayout from "../layouts/BaseLayout.astro";
import BookingForm from "../components/BookingForm.tsx";

const studioParam = Astro.url.searchParams.get("studio") ?? undefined;
const valid = ["Studio North", "Studio Depot", "Either room"];
const defaultStudio = studioParam && valid.includes(studioParam) ? studioParam : undefined;
---
<BaseLayout title="Book a Studio" description="Send a booking request for Studio North or Studio Depot. Pick a date and a room — we reply the same day. No deposit up front.">
  <section class="mx-auto max-w-[1440px] px-5 md:px-16 py-12 md:py-20 grid grid-cols-1 md:grid-cols-12 gap-12">
    <div class="md:col-span-4">
      <span class="kicker text-primary block mb-3">Book a studio</span>
      <h1 class="font-display font-black uppercase tracking-tight text-4xl md:text-5xl leading-[0.95]">Tell us the date</h1>
      <p class="text-muted text-lg mt-5">Pick a studio and a date and send the request. We reply the same day to confirm the slot and send a door code.</p>
      <div class="hidden md:block light-line h-24 w-px mt-10"></div>
    </div>
    <div class="md:col-span-8">
      <BookingForm defaultStudio={defaultStudio} client:load />
    </div>
  </section>
</BaseLayout>
