---
import BaseLayout from "../layouts/BaseLayout.astro";
import MapFacade from "../components/MapFacade.astro";
import { SITE } from "../lib/site";

const jsonld = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": SITE.url + "/#business",
    name: SITE.name,
    url: SITE.url,
    email: SITE.email,
    priceRange: "€€",
    address: {
      "@type": "PostalAddress",
      streetAddress: "Tram Depot District",
      addressLocality: "Prague 7",
      postalCode: "170 00",
      addressCountry: "CZ",
    },
    geo: { "@type": "GeoCoordinates", latitude: SITE.geo.lat, longitude: SITE.geo.lng },
    openingHoursSpecification: [
      {
        "@type": "OpeningHoursSpecification",
        dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
        opens: "08:00",
        closes: "20:00",
      },
    ],
  },
];

const notes = [
  { k: "Neighborhood", v: "Prague 7, the old tram depot district — ten minutes from the river, trams 12 and 17 at the door." },
  { k: "Loading dock", v: "Drive-in door clears a small hatchback or sedan; tell us the make so we can lay down floor protection." },
  { k: "Parking & load-in", v: "A small lot holds two cars; a freight lift off the dock handles heavy carts." },
  { k: "Hours", v: SITE.hours },
];
---
<BaseLayout title="Find Us" description="Glasswing Studio Rentals — Prague 7 tram depot district. Loading-dock access, parking, and hours." jsonld={jsonld}>
  <section class="mx-auto max-w-[1440px] px-5 md:px-16 pt-12 md:pt-20 pb-12">
    <div class="flex gap-5">
      <div class="light-line shrink-0"></div>
      <div>
        <span class="kicker text-primary block mb-3">Find us</span>
        <h1 class="font-display font-black uppercase tracking-tight text-4xl md:text-6xl leading-[0.95]">Prague 7, the tram depot</h1>
        <p class="text-muted text-lg mt-5 max-w-xl">{SITE.address}. {SITE.geo.lat}° N, {SITE.geo.lng}° E.</p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[1440px] px-5 md:px-16 pb-section grid grid-cols-1 md:grid-cols-12 gap-10">
    <div class="md:col-span-7 reveal">
      <MapFacade />
    </div>
    <dl class="md:col-span-5 reveal">
      {notes.map((n) => (
        <div class="border-b border-border py-5 first:border-t">
          <dt class="kicker text-primary mb-2">{n.k}</dt>
          <dd class="text-muted">{n.v}</dd>
        </div>
      ))}
      <div class="pt-8">
        <a href={`mailto:${SITE.email}`} class="font-display font-bold uppercase text-xl md:text-2xl tracking-tight hover:text-primary transition-colors">{SITE.email}</a>
        <a href="/book" class="btn-primary mt-6">Check a date</a>
      </div>
    </dl>
  </section>
</BaseLayout>
